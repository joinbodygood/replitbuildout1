# ============================================
# Body Good Studio — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# === DATABASE ===
DATABASE_URL="postgresql://user:password@host:5432/bodygood?schema=public"

# === PAYPAL ===
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox  # sandbox or live

# === WEBHOOKS ===
N8N_WEBHOOK_URL=     # n8n automation webhook (fire-and-forget)

# === CLAUDE API ===
ANTHROPIC_API_KEY=

# === PA MODULE (new) ===
# Stedi — eligibility verification
STEDI_API_KEY=
STEDI_PORTAL_EMAIL=          # fallback portal automation
STEDI_PORTAL_PASSWORD=       # fallback portal automation

# S3 — insurance card image storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# PA webhooks — fires on stage changes, approvals, denials
PA_STATUS_WEBHOOK_URL=

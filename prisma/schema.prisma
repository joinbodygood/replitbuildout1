generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  String              @id @default(cuid())
  slug                String              @unique
  category            String
  requiresPrescription Boolean            @default(true)
  isActive            Boolean             @default(true)
  isFeatured          Boolean             @default(false)
  sortOrder           Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  translations        ProductTranslation[]
  variants            ProductVariant[]
  images              ProductImage[]

  @@index([category])
  @@index([isActive, sortOrder])
}

model ProductTranslation {
  id              String   @id @default(cuid())
  productId       String
  locale          String
  name            String
  descriptionShort String
  descriptionLong  String   @db.Text
  seoTitle        String?
  seoDescription  String?

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  sku             String   @unique
  doseLevel       String?
  supplyDuration  String?
  price           Int
  compareAtPrice  Int?
  isAvailable     Boolean  @default(true)
  sortOrder       Int      @default(0)

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isAvailable])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model InsuranceProbability {
  id          String   @id @default(cuid())
  carrier     String
  planType    String
  state       String
  medication  String
  probability Int
  notes       String?
  updatedAt   DateTime @updatedAt

  @@unique([carrier, planType, state, medication])
  @@index([carrier, state])
}

model QuizLead {
  id           String   @id @default(cuid())
  email        String
  phone        String?
  bmi          Float?
  quizOutcome  String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  locale       String   @default("en")
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model FaqItem {
  id        String   @id @default(cuid())
  category  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  translations FaqTranslation[]

  @@index([category, isActive, sortOrder])
}

model FaqTranslation {
  id       String  @id @default(cuid())
  faqId    String
  locale   String
  question String
  answer   String  @db.Text

  faq      FaqItem @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, locale])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  String              @id @default(cuid())
  slug                String              @unique
  sku                 String?             @unique
  category            String
  productType         String              @default("rx") // rx | supplement | consultation
  programTag          String?
  fulfillment         String              @default("direct_ship")
  dosageForm          String?
  forGender           String              @default("all")
  pathBConsultPrice   Int?
  pathBOngoingPrice   Int?
  fccMedicationName   String?
  fccConcentration    String?
  requiresPrescription Boolean            @default(true)
  isActive            Boolean             @default(true)
  isFeatured          Boolean             @default(false)
  sortOrder           Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  translations        ProductTranslation[]
  variants            ProductVariant[]
  images              ProductImage[]

  @@index([category])
  @@index([isActive, sortOrder])
}

model ProductTranslation {
  id              String   @id @default(cuid())
  productId       String
  locale          String
  name            String
  descriptionShort String
  descriptionLong  String
  seoTitle        String?
  seoDescription  String?

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  sku             String   @unique
  label           String?
  doseLevel       String?
  supplyDuration  String?
  price           Int
  compareAtPrice  Int?
  isAvailable     Boolean  @default(true)
  sortOrder       Int      @default(0)

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isAvailable])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model InsuranceProbability {
  id          String   @id @default(cuid())
  carrier     String
  planType    String
  state       String
  medication  String
  probability Int
  notes       String?
  updatedAt   DateTime @updatedAt

  @@unique([carrier, planType, state, medication])
  @@index([carrier, state])
}

model QuizLead {
  id                String    @id @default(cuid())
  email             String
  firstName         String?
  phone             String?
  state             String?
  weightGoal        String?
  story             String?
  needleComfort     String?
  insuranceInterest String?
  insuranceType     String?
  priority          String?
  timeline          String?
  quizOutcome       String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  locale            String    @default("en")
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
}

model FaqItem {
  id        String   @id @default(cuid())
  category  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  translations FaqTranslation[]

  @@index([category, isActive, sortOrder])
}

model FaqTranslation {
  id       String  @id @default(cuid())
  faqId    String
  locale   String
  question String
  answer   String

  faq      FaqItem @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, locale])
}

// ─── Orders ─────────────────────────────────────────

model Order {
  id                   String      @id @default(cuid())
  email                String
  phone                String?
  status               String      @default("pending_intake") // pending_intake, processing, shipped, delivered, cancelled, refunded
  subtotal             Int         // cents
  discount             Int         @default(0) // cents
  total                Int         // cents
  discountCode         String?
  paypalOrderId        String?
  paypalSubscriptionId String?     // set for subscription orders
  shippingName         String?
  shippingAddress      String?
  shippingCity         String?
  shippingState        String?
  shippingZip          String?
  locale               String      @default("en")
  notes                String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  items                OrderItem[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([paypalSubscriptionId])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productName String
  variantLabel String
  sku         String?
  price       Int    // cents
  quantity    Int
  productType String @default("rx") // rx | supplement | consultation — used for fulfillment routing
  shopifyFulfillmentStatus String? // pending | processing | shipped | delivered | failed
  trackingNumber  String?
  trackingCarrier String?

  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productType])
}

// ─── Discount Codes ─────────────────────────────────

model DiscountCode {
  id            String    @id @default(cuid())
  code          String    @unique
  type          String    // "percentage" or "fixed"
  value         Int       // percentage (e.g., 10 for 10%) or cents (e.g., 2500 for $25)
  minOrderValue Int?      // cents, minimum order to apply
  maxUses       Int?      // null = unlimited
  usedCount     Int       @default(0)
  productSlug   String?   // null = site-wide, or specific product slug
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([code, isActive])
}

// ─── Referrals ──────────────────────────────────────

model Referral {
  id              String   @id @default(cuid())
  referrerEmail   String
  referrerCode    String   @unique
  referredEmail   String?
  referredOrderId String?
  creditAmount    Int      @default(2500) // cents ($25)
  referrerCredited Boolean @default(false)
  referredCredited Boolean @default(false)
  status          String   @default("pending") // pending, completed, expired
  createdAt       DateTime @default(now())

  @@index([referrerEmail])
  @@index([referrerCode])
}

// ─── Reviews ────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  productSlug String?
  email       String
  name        String
  rating      Int      // 1-5
  title       String?
  body        String
  photoUrl    String?
  isVerified  Boolean  @default(false)
  isApproved  Boolean  @default(false) // admin must approve before display
  locale      String   @default("en")
  createdAt   DateTime @default(now())

  @@index([productSlug, isApproved])
  @@index([isApproved, createdAt])
}

// ─── Admin ──────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("support") // super_admin, clinical_admin, provider, support, marketing, developer
  passwordHash String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     AdminSession[]
  auditLogs    AdminAuditLog[]

  @@index([email])
  @@index([role])
}

model AdminSession {
  id          String   @id @default(cuid())
  adminId     String
  token       String   @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  admin       AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // e.g. "order.refund", "patient.suspend", "discount.create"
  entityType String?  // "order", "patient", etc.
  entityId   String?
  details    String?  // JSON string of change details
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin      AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Blog ───────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  category    String   // "glp1-education", "weight-loss-tips", "insurance-guides", "patient-stories"
  authorName  String   @default("Dr. Linda Moleon, MD")
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations BlogPostTranslation[]

  @@index([isPublished, publishedAt])
  @@index([category])
}

model BlogPostTranslation {
  id          String @id @default(cuid())
  postId      String
  locale      String // "en" or "es"
  title       String
  excerpt     String
  body        String // markdown/rich text
  seoTitle    String?
  seoDescription String?

  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

// ─── PayPal Subscriptions ────────────────────────────

model PaypalPlan {
  id                 String   @id @default(cuid())
  paypalPlanId       String   @unique
  paypalProductId    String
  pricePerCycleCents Int
  totalCycles        Int      // 0 = infinite (ongoing monthly), 3 or 6 for fixed-term
  setupFeeCents      Int      @default(0)
  description        String
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())

  @@unique([pricePerCycleCents, totalCycles, setupFeeCents])
  @@index([pricePerCycleCents, totalCycles])
}

model PaypalWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  resourceId  String?
  payload     String
  processedAt DateTime @default(now())

  @@index([eventId])
  @@index([resourceId])
}

// ─── Shopify Integration ─────────────────────────────

model ShopifyToken {
  id        String   @id @default(cuid())
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopifyMapping {
  id               String   @id @default(cuid())
  productId        String?
  ourSku           String   @unique
  shopifyProductId String
  shopifyVariantId String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ourSku])
  @@index([productId])
}

model ShopifyOrder {
  id              String    @id @default(cuid())
  orderId         String
  shopifyOrderId  String    @unique
  shopifyOrderUrl String?
  status          String    @default("processing") // processing | shipped | delivered | failed
  trackingNumber  String?
  trackingCarrier String?
  shippedAt       DateTime?
  failureReason   String?
  retryCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId])
  @@index([shopifyOrderId])
  @@index([status])
}

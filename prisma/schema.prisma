generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  String              @id @default(cuid())
  slug                String              @unique
  sku                 String?             @unique
  category            String
  productType         String              @default("rx") // rx | supplement | consultation
  programTag          String?
  fulfillment         String              @default("direct_ship")
  dosageForm          String?
  forGender           String              @default("all")
  pathBConsultPrice   Int?
  pathBOngoingPrice   Int?
  fccMedicationName   String?
  fccConcentration    String?
  requiresPrescription Boolean            @default(true)
  isActive            Boolean             @default(true)
  isFeatured          Boolean             @default(false)
  sortOrder           Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  translations        ProductTranslation[]
  variants            ProductVariant[]
  images              ProductImage[]

  @@index([category])
  @@index([isActive, sortOrder])
}

model ProductTranslation {
  id              String   @id @default(cuid())
  productId       String
  locale          String
  name            String
  descriptionShort String
  descriptionLong  String
  seoTitle        String?
  seoDescription  String?

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  sku             String   @unique
  label           String?
  doseLevel       String?
  supplyDuration  String?
  price           Int
  compareAtPrice  Int?
  isAvailable     Boolean  @default(true)
  sortOrder       Int      @default(0)

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isAvailable])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model QuizLead {
  id                String    @id @default(cuid())
  email             String
  firstName         String?
  phone             String?
  state             String?
  weightGoal        String?
  story             String?
  needleComfort     String?
  insuranceInterest String?
  insuranceType     String?
  priority          String?
  timeline          String?
  quizOutcome       String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  locale            String    @default("en")
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
}

model FaqItem {
  id        String   @id @default(cuid())
  category  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  translations FaqTranslation[]

  @@index([category, isActive, sortOrder])
}

model FaqTranslation {
  id       String  @id @default(cuid())
  faqId    String
  locale   String
  question String
  answer   String

  faq      FaqItem @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, locale])
}

// ─── Orders ─────────────────────────────────────────

model Order {
  id                   String      @id @default(cuid())
  email                String
  phone                String?
  status               String      @default("pending_intake") // pending_intake, processing, shipped, delivered, cancelled, refunded
  subtotal             Int         // cents
  discount             Int         @default(0) // cents
  total                Int         // cents
  discountCode         String?
  paypalOrderId        String?
  paypalSubscriptionId String?     // set for subscription orders
  shippingName         String?
  shippingAddress      String?
  shippingCity         String?
  shippingState        String?
  shippingZip          String?
  locale               String      @default("en")
  notes                String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  items                OrderItem[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([paypalSubscriptionId])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productName String
  variantLabel String
  sku         String?
  price       Int    // cents
  quantity    Int
  productType String @default("rx") // rx | supplement | consultation — used for fulfillment routing
  shopifyFulfillmentStatus String? // pending | processing | shipped | delivered | failed
  trackingNumber  String?
  trackingCarrier String?

  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productType])
}

// ─── Discount Codes ─────────────────────────────────

model DiscountCode {
  id            String    @id @default(cuid())
  code          String    @unique
  type          String    // "percentage" or "fixed"
  value         Int       // percentage (e.g., 10 for 10%) or cents (e.g., 2500 for $25)
  minOrderValue Int?      // cents, minimum order to apply
  maxUses       Int?      // null = unlimited
  usedCount     Int       @default(0)
  productSlug   String?   // null = site-wide, or specific product slug
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([code, isActive])
}

// ─── Referrals ──────────────────────────────────────

model Referral {
  id              String   @id @default(cuid())
  referrerEmail   String
  referrerCode    String   @unique
  referredEmail   String?
  referredOrderId String?
  creditAmount    Int      @default(2500) // cents ($25)
  referrerCredited Boolean @default(false)
  referredCredited Boolean @default(false)
  status          String   @default("pending") // pending, completed, expired
  createdAt       DateTime @default(now())

  @@index([referrerEmail])
  @@index([referrerCode])
}

// ─── Reviews ────────────────────────────────────────

model Review {
  id                String   @id @default(cuid())
  productSlug       String?
  email             String
  name              String
  rating            Int                        // 1-5
  title             String?
  body              String
  photoUrl          String?
  isVerified        Boolean  @default(false)
  isApproved        Boolean  @default(false)  // admin must approve before display
  isFeatured        Boolean  @default(false)  // pinned / highlighted
  shopifyId         String?  @unique          // Judge.me review ID for dedup
  shopifyProductId  String?                   // original Shopify product ID (kept for unmapped reviews)
  locale            String   @default("en")
  source            String   @default("organic") // "organic" | "imported"
  createdAt         DateTime @default(now())

  @@index([productSlug, isApproved])
  @@index([isApproved, isFeatured, createdAt])
}

// ─── Imported Customers (Shopify migration) ────────────

model ImportedCustomer {
  id               String    @id @default(cuid())
  shopifyId        String?   @unique
  email            String    @unique
  firstName        String?
  lastName         String?
  phone            String?
  tags             String    @default("")    // comma-separated Shopify tags (raw)
  segments         String[]                 // derived segment keys, e.g. ["self-pay","vip"]
  ordersCount      Int       @default(0)
  totalSpent       Float     @default(0)
  state            String    @default("enabled")
  shopifyCreatedAt DateTime?                // original Shopify created_at
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([email])
  @@index([segments])
  @@index([ordersCount])
}

// ─── Admin ──────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("support") // super_admin, clinical_admin, provider, support, marketing, developer
  passwordHash String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     AdminSession[]
  auditLogs    AdminAuditLog[]

  @@index([email])
  @@index([role])
}

model AdminSession {
  id          String   @id @default(cuid())
  adminId     String
  token       String   @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  admin       AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // e.g. "order.refund", "patient.suspend", "discount.create"
  entityType String?  // "order", "patient", etc.
  entityId   String?
  details    String?  // JSON string of change details
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin      AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Blog ───────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  category    String   // "glp1-education", "weight-loss-tips", "insurance-guides", "patient-stories"
  authorName  String   @default("Dr. Linda Moleon, MD")
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations BlogPostTranslation[]

  @@index([isPublished, publishedAt])
  @@index([category])
}

model BlogPostTranslation {
  id          String @id @default(cuid())
  postId      String
  locale      String // "en" or "es"
  title       String
  excerpt     String
  body        String // markdown/rich text
  seoTitle    String?
  seoDescription String?

  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

// ─── PayPal Subscriptions ────────────────────────────

model PaypalPlan {
  id                 String   @id @default(cuid())
  paypalPlanId       String   @unique
  paypalProductId    String
  pricePerCycleCents Int
  totalCycles        Int      // 0 = infinite (ongoing monthly), 3 or 6 for fixed-term
  setupFeeCents      Int      @default(0)
  description        String
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())

  @@unique([pricePerCycleCents, totalCycles, setupFeeCents])
  @@index([pricePerCycleCents, totalCycles])
}

model PaypalWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  resourceId  String?
  payload     String
  processedAt DateTime @default(now())

  @@index([eventId])
  @@index([resourceId])
}

// ─── Shopify Integration ─────────────────────────────

model ShopifyToken {
  id        String   @id @default(cuid())
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopifyMapping {
  id               String   @id @default(cuid())
  productId        String?
  ourSku           String   @unique
  shopifyProductId String
  shopifyVariantId String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ourSku])
  @@index([productId])
}

// ─── Referral Members (program / imported) ─────────
model ReferralMember {
  id                   String   @id @default(cuid())
  email                String   @unique
  firstName            String
  lastName             String
  phone                String?
  referralCode         String   @unique
  status               String   @default("enabled")   // "enabled" | "disabled"
  totalClicks          Int      @default(0)
  successfulReferrals  Int      @default(0)
  totalReferralRevenue Int      @default(0)            // cents
  legacyReferralUrl    String?                         // old Shopjar go.refrl.co/... URL
  linkedCustomerEmail  String?                         // email of matched ImportedCustomer
  notifiedAt           DateTime?                       // when "new link" email was last sent
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([email])
  @@index([referralCode])
  @@index([status])
}

// ─── Legal Pages (CMS-editable) ─────────────────────
model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique   // e.g. "privacy-policy"
  title     String
  titleEs   String?            // Spanish title
  content   String   @db.Text  // raw HTML (English)
  contentEs String?  @db.Text  // raw HTML (Spanish)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([slug])
}

// ─── Import Activity Log ─────────────────────────────
model ImportLog {
  id          String    @id @default(cuid())
  type        String    // "customers" | "reviews" | "referrals" | "blog" | "pages"
  filename    String?
  status      String    @default("completed")  // "completed" | "failed"
  imported    Int       @default(0)
  skipped     Int       @default(0)
  errors      Int       @default(0)
  total       Int       @default(0)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([createdAt])
}

model ShopifyOrder {
  id              String    @id @default(cuid())
  orderId         String
  shopifyOrderId  String    @unique
  shopifyOrderUrl String?
  status          String    @default("processing") // processing | shipped | delivered | failed
  trackingNumber  String?
  trackingCarrier String?
  shippedAt       DateTime?
  failureReason   String?
  retryCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId])
  @@index([shopifyOrderId])
  @@index([status])
}

// ──────────────────────────────────────────────────────────────────────
// Insurance Probability Checker v2 (replaces InsuranceProbability)
// ──────────────────────────────────────────────────────────────────────

enum InsuranceOrigin {
  aca
  medicare
  medicaid
  employer
  federal_military
}

enum CoverageStatus {
  not_on_formulary
  unlikely
  coverage_with_pa
  high_probability
}

enum CoverageSource {
  healthcare_gov_api
  qhp_file
  medicare_part_d
  medicaid_state
  pbm_baseline
  carrier_scrape
  manual
  default_fallback
}

enum ResultBucket {
  not_on_formulary
  unlikely
  coverage_with_pa
  high_probability
}

model CoverageIndex {
  id              String           @id @default(cuid())
  insuranceOrigin InsuranceOrigin
  carrierKey      String
  planId          String?
  state           String
  pbm             String?
  medication      String           // wegovy | zepbound | mounjaro | ozempic | foundayo
  indicationKey   String           // weight_loss | t2d | cv | osa | mash
  status          CoverageStatus
  probLow         Int
  probHigh        Int
  paRequired      Boolean          @default(true)
  stepTherapy     Boolean          @default(false)
  tier            Int?
  notes           String?
  source          CoverageSource
  sourceEvidenceUrl String?
  lastSeenAt      DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([carrierKey, state, medication, indicationKey], name: "coverage_index_no_plan")
  @@unique([planId, medication, indicationKey], name: "coverage_index_with_plan")
  @@index([insuranceOrigin, carrierKey, state])
  @@index([planId])
  @@index([medication, indicationKey])
  @@index([lastSeenAt])
}

model CoverageDefault {
  id            String         @id @default(cuid())
  medication    String
  indicationKey String
  probLow       Int
  probHigh      Int
  paRequired    Boolean        @default(true)
  notes         String?
  updatedAt     DateTime       @updatedAt

  @@unique([medication, indicationKey])
}

model AcaPlanDirectory {
  id          String   @id @default(cuid())
  planId      String   @unique // HIOS 14-digit
  carrierKey  String
  state       String
  planName    String
  planYear    Int
  metalLevel  String?
  lastSeenAt  DateTime @default(now())

  @@index([carrierKey, state])
  @@index([state, planName])
}

model InsuranceCheckLead {
  id                 String       @id @default(cuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  firstName          String
  email              String
  phone              String?
  smsConsent         Boolean      @default(false)
  emailConsent       Boolean      @default(true)

  intakeJson         Json
  resultJson         Json
  resultHistory      Json?
  resultBucket       ResultBucket
  bestMedication     String

  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  ipAddress          String?
  userAgent          String?

  zohoLeadId         String?
  convertedToPaid    Boolean      @default(false)
  convertedAt        DateTime?

  locale             String       @default("en")

  @@index([email])
  @@index([createdAt])
  @@index([resultBucket])
}

model WorkerRun {
  id             String   @id @default(cuid())
  workerName     String
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  status         String   // running | success | error
  rowsWritten    Int      @default(0)
  errorMessage   String?

  @@index([workerName, startedAt])
  @@index([status])
}
